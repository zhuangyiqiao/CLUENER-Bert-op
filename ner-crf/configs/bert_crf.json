{
  "data_dir": ".data",
  "train_path": ".data/train.json",
  "dev_path": ".data/dev.json",
  "test_path": ".data/test.json",
  "output_dir": "./outputs",

  "model": {
    "pretrained_name": "hfl/chinese-bert-wwm-ext",
    "dropout": 0.1,
    "use_crf": true,
    "seed": 42
  },
  "data": {
    "max_length": 256,
    "pad_label": "O"
  },
  "train": {
    "device": "auto",
    "num_epochs": 5,
    "train_batch_size": 32,
    "eval_batch_size": 32,
    "learning_rate": 3e-5,
    "weight_decay": 0.01,
    "warmup_ratio": 0.1,
    "max_grad_norm": 1.0,
    "fp16": false,
    "gradient_accumulation_steps": 1,
    "log_every_steps": 50,
    "eval_every_steps": 0
  },

  "labels": {
    "label2id": {
      "O": 0,
      "B-address": 1,
      "B-book": 2,
      "B-company": 3,
      "B-game": 4,
      "B-government": 5,
      "B-movie": 6,
      "B-name": 7,
      "B-organization": 8,
      "B-position": 9,
      "B-scene": 10,
      "I-address": 11,
      "I-book": 12,
      "I-company": 13,
      "I-game": 14,
      "I-government": 15,
      "I-movie": 16,
      "I-name": 17,
      "I-organization": 18,
      "I-position": 19,
      "I-scene": 20,
      "S-address": 21,
      "S-book": 22,
      "S-company": 23,
      "S-game": 24,
      "S-government": 25,
      "S-movie": 26,
      "S-name": 27,
      "S-organization": 28,
      "S-position": 29,
      "S-scene": 30,
      "<START>": 31,
      "<STOP>": 32
    }
  }
}